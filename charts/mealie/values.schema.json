{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mealie", "service", "data"],
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the name of the chart"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full name of the chart"
    },
    "namespaceOverride": {
      "type": "string",
      "description": "Override the namespace of the chart"
    },
    "mealie": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "description": "Number of replicas"
        },
        "strategyType": {
          "type": "string",
          "description": "The deployment strategy type",
          "enum": ["Recreate", "RollingUpdate"]
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string",
              "description": "The image repository"
            },
            "tag": {
              "type": "string",
              "description": "The image tag"
            }
          },
          "required": ["repository"]
        },
        "securityContext": {
          "type": "object",
          "description": "Security context for the container",
          "properties": {
            "readOnlyRootFilesystem": {
              "type": "boolean",
              "description": "Whether to run mealie with a read-only root filesystem"
            },
            "runAsUser": {
              "type": "integer",
              "description": "The user ID to run mealie as"
            },
            "runAsGroup": {
              "type": "integer",
              "description": "The group ID to run mealie as"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resource requests and limits",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "memory": {
                  "type": "string",
                  "description": "Memory request"
                },
                "cpu": {
                  "type": "string",
                  "description": "CPU request"
                }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "memory": {
                  "type": "string",
                  "description": "Memory limit"
                },
                "cpu": {
                  "type": "string",
                  "description": "CPU limit"
                }
              }
            }
          }
        },
        "livenessProbe": {
          "type": "object",
          "description": "The livenessProbe configuration for the mealie pod",
          "additionalProperties": true
        },
        "readinessProbe": {
          "type": "object",
          "description": "The readinessProbe configuration for the mealie pod",
          "additionalProperties": true
        },
        "startupProbe": {
          "type": "object",
          "description": "The startupProbe configuration for the mealie pod",
          "additionalProperties": true
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to apply to the mealie pod",
          "additionalProperties": {
            "type": "string"
          }
        },
        "env": {
          "type": "array",
          "description": "The environment variables to set for the mealie pod",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the environment variable"
              },
              "value": {
                "type": "string",
                "description": "The value of the environment variable"
              }
            },
            "required": ["name", "value"]
          }
        },
        "envFrom": {
          "type": "array",
          "description": "The environment variables to set for the mealie pod from a config map or secret",
          "items": {
            "type": "object",
            "properties": {
              "configMapRef": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The name of the config map"
                  }
                },
                "required": ["name"]
              },
              "secretRef": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The name of the secret"
                  }
                },
                "required": ["name"]
              }
            },
            "oneOf": [
              {"required": ["configMapRef"]},
              {"required": ["secretRef"]}
            ]
          }
        }
      },
      "required": ["replicas", "image"]
    },
    "service": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the service",
          "additionalProperties": true
        },
        "ports": {
          "type": "array",
          "description": "List of ports to expose",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the port"
              },
              "port": {
                "type": "integer",
                "description": "The service port"
              },
              "protocol": {
                "type": "string",
                "description": "The protocol used by the port",
                "enum": ["TCP", "UDP"]
              }
            },
            "required": ["name", "port", "protocol"]
          }
        },
        "type": {
          "type": "string",
          "description": "The service type",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        }
      },
      "required": ["ports", "type"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create an Ingress resource"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the Ingress",
          "additionalProperties": true
        },
        "mainPort": {
          "type": "integer",
          "description": "The main port to route traffic to"
        },
        "ingressClassName": {
          "type": "string",
          "description": "The ingress class name"
        },
        "hosts": {
          "type": "array",
          "description": "List of hosts for the Ingress",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "tls": {
          "type": "array",
          "description": "TLS configuration for the Ingress",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the PVC",
          "additionalProperties": true
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether to create a PersistentVolumeClaim for application data"
        },
        "existingClaim": {
          "type": "string",
          "description": "Use an existing PVC instead of creating one"
        },
        "size": {
          "type": "string",
          "description": "The size of the PVC"
        },
        "accessMode": {
          "type": "string",
          "description": "The access mode for the PVC",
          "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"]
        },
        "retain": {
          "type": "boolean",
          "description": "Whether to retain the PVC when the release is deleted"
        }
      },
      "required": ["enabled", "size", "accessMode"]
    }
  }
}
