{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["bbe", "ingress-nginx"],
  "properties": {
    "bbe": {
      "type": "object",
      "properties": {
        "metallb": {
          "type": "object",
          "properties": {
            "blocky": {
              "type": "object",
              "properties": {
                "ipAddressPool": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The IP address pool to use for the Blocky service"
                }
              },
              "required": ["ipAddressPool"]
            }
          },
          "required": ["blocky"]
        }
      },
      "required": ["metallb"],
      "certManager": {
        "type": "object",
        "description": "cert-manager configuration for automatic TLS certificate issuance via Let's Encrypt",
        "properties": {
          "acme": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "description": "Email address for the Let's Encrypt account. Required to activate the ClusterIssuer."
              },
              "staging": {
                "type": "boolean",
                "description": "Use the Let's Encrypt staging CA. Set to true to test without hitting rate limits."
              }
            }
          }
        }
      }
    },
    "ingress-nginx": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "controller": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "service": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "loadBalancerIP": {
                  "type": "string",
                  "minLength": 1,
                  "description": "The IP address to use for the load balancer"
                }
              },
              "required": ["loadBalancerIP"]
            }
          },
          "required": ["service"]
        }
      },
      "required": ["controller"]
    }
  }
}
